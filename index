// ============================================================
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function loading(show,txt='Betöltés...'){
  document.getElementById('ltxt').textContent=txt;
  document.getElementById('loading').classList.toggle('show',show);
}
function switchTab(t){
  ['create','join','wait'].forEach(n=>{
    document.getElementById('tc-'+n).classList.toggle('on',n===t);
  });
  document.querySelectorAll('.tab').forEach((b,i)=>b.classList.toggle('on',['create','join'][i]===t));
}
function pickA(el,ctx){
  document.querySelectorAll(`#${ctx==='c'?'ca':'ja'}-sel .aopt`).forEach(o=>o.classList.remove('on'));
  el.classList.add('on');
  if(ctx==='c') animalC=el.dataset.a; else animalJ=el.dataset.a;
}
function genCode(){const c='ABCDEFGHJKLMNPQRSTUVWXYZ';return Array.from({length:4},()=>c[Math.floor(Math.random()*c.length)]).join('');}
function genId(){return Math.random().toString(36).substr(2,9)+Date.now().toString(36);}

// ============================================================
//  CREATE ROOM
// ============================================================
async function createRoom(){
  const name=document.getElementById('cname').value.trim();
  if(!name){document.getElementById('cerr').textContent='Kérlek adj meg egy nevet!';return;}
  document.getElementById('cerr').textContent='';
  loading(true,'Szoba létrehozása...');
  myId=genId(); isHost=true;
  const code=genCode();
  myRoom=code;
  const roomData={
    host:myId, status:'waiting',
    players:{[myId]:{name,icon:animalC,position:1,skipTurns:0,bonusNext:0,order:0}},
    currentPlayerIdx:0, deck:mkDeck(), log:[], lastAction:null,
  };
  await db.ref('rooms/'+code).set(roomData);
  loading(false);
  document.getElementById('dcode').textContent=code;
  document.getElementById('hcode').textContent=code;
  switchTab('wait');
  listenLobby(code);
}

// ============================================================
//  JOIN ROOM
// ============================================================
async function joinRoom(){
  const code=document.getElementById('jcode').value.trim().toUpperCase();
  const name=document.getElementById('jname').value.trim();
  if(code.length!==4){document.getElementById('jerr').textContent='4 betűs kód kell!';return;}
  if(!name){document.getElementById('jerr').textContent='Add meg a neved!';return;}
  document.getElementById('jerr').textContent='';
  loading(true,'Szoba keresése...');
  const snap=await db.ref('rooms/'+code).get();
  if(!snap.exists()){loading(false);document.getElementById('jerr').textContent='Nincs ilyen szoba!';return;}
  const room=snap.val();
  if(room.status==='finished'){loading(false);document.getElementById('jerr').textContent='Ez a játék már véget ért.';return;}
  myId=genId(); isHost=false; myRoom=code;
  const order=Object.keys(room.players||{}).length;
  await db.ref('rooms/'+code+'/players/'+myId).set({name,icon:animalJ,position:1,skipTurns:0,bonusNext:0,order});
  loading(false);
  document.getElementById('hcode').textContent=code;
  document.getElementById('startbtn').disabled=true;
  if(room.status==='playing'){
    showScreen('game'); drawBoard(); listenGame(code);
  } else {
    switchTab('wait'); listenLobby(code);
  }
}

// ============================================================
//  LOBBY LISTENER
// ============================================================
function listenLobby(code){
  db.ref('rooms/'+code).on('value',snap=>{
    if(!snap.exists()) return;
    const room=snap.val();
    renderWaiting(room.players||{});
    if(room.status==='playing'){
      db.ref('rooms/'+code).off();
      showScreen('game'); drawBoard(); listenGame(code);
    }
  });
}
function renderWaiting(players){
  const arr=Object.values(players).sort((a,b)=>a.order-b.order);
  document.getElementById('wlist').innerHTML=arr.map(p=>`<div class="wplayer"><span style="font-size:22px">${p.icon}</span><span>${p.name}</span></div>`).join('');
  document.getElementById('wstatus').textContent=`${arr.length} játékos csatlakozott${arr.length<2?' (min. 2 fő)':''}`;
  document.getElementById('startbtn').disabled=arr.length<2||!isHost;
}
async function hostStart(){
  if(!isHost) return;
  await db.ref('rooms/'+myRoom+'/status').set('playing');
}

// ============================================================
//  GAME LISTENER
// ============================================================
function listenGame(code){
  roomRef=db.ref('rooms/'+code);
  roomRef.on('value',snap=>{
    if(!snap.exists()) return;
    onState(snap.val());
  });
}

function sortP(players){
  return Object.entries(players).sort((a,b)=>a[1].order-b[1].order).map(([id,p])=>({id,...p}));
}

function onState(room){
  if(!room) return;
  if(room.status==='finished'){if(room.winner) showWin(room.winner); return;}
  const players=sortP(room.players||{});
  const cidx=room.currentPlayerIdx||0;
  renderPlayers(players,cidx);
  renderPawns(players,cidx);
  document.getElementById('curp').textContent=players[cidx]?`${players[cidx].icon} ${players[cidx].name}`:'';
  renderRoll(players,cidx);
  if(room.log) renderLog(room.log);
  const a=room.lastAction;
  if(a&&a.ts&&a.ts!==lastTs) handleAction(room,players,cidx);
}

function renderRoll(players,cidx){
  const area=document.getElementById('rarea');
  const isme=players[cidx]&&players[cidx].id===myId;
  if(isme){
    area.innerHTML='<button class="rbtn" id="rbtn" onclick="doRoll()">🎲 Dobás!</button>';
  } else {
    const p=players[cidx];
    area.innerHTML=`<div class="waittxt">⏳ ${p?p.name:''} dobása...</div>`;
  }
}

