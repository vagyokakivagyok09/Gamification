function leaveGame(){
  if(roomRef){roomRef.off();roomRef=null;}
  document.getElementById('win').classList.remove('show');
  document.getElementById('cconf').innerHTML='';
  document.getElementById('d1').textContent='🎲';
  document.getElementById('d2').textContent='🎲';
  document.getElementById('elog').innerHTML='';
  lastTs=0;myId=null;myRoom=null;isHost=false;
  showScreen('lobby');switchTab('create');
}
