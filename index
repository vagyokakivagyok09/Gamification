// ============================================================
const FACES=['⚀','⚁','⚂','⚃','⚄','⚅'];
async function doRoll(){
  const btn=document.getElementById('rbtn');
  if(btn) btn.disabled=true;
  const d1=document.getElementById('d1'),d2=document.getElementById('d2');
  d1.classList.add('roll'); d2.classList.add('roll');
  let t=0;
  const anim=setInterval(()=>{
    d1.textContent=FACES[Math.floor(Math.random()*6)];
    d2.textContent=FACES[Math.floor(Math.random()*6)];
    if(++t>8){
      clearInterval(anim);
      d1.classList.remove('roll'); d2.classList.remove('roll');
      const v1=Math.ceil(Math.random()*6),v2=Math.ceil(Math.random()*6);
      d1.textContent=FACES[v1-1]; d2.textContent=FACES[v2-1];
      processMove(v1,v2);
    }
  },80);
}

async function processMove(v1,v2){
  const snap=await db.ref('rooms/'+myRoom).get();
  const room=snap.val(); if(!room) return;
  const players=sortP(room.players||{});
  const cidx=room.currentPlayerIdx||0;
  const me=players[cidx];
  if(!me||me.id!==myId) return;

  if(me.skipTurns>0){
    const nextIdx=(cidx+1)%players.length;
    await db.ref('rooms/'+myRoom).update({
      [`players/${me.id}/skipTurns`]:me.skipTurns-1,
      currentPlayerIdx:nextIdx,
      log:[...(room.log||[]),`⏸ ${me.name} kimarad`].slice(-30),
      lastAction:{type:'skip',ts:Date.now()}
    });
    return;
  }

  let total=v1+v2+(me.bonusNext||0);
  document.getElementById('dres').textContent=`🎲 ${v1}+${v2}=${total} lépés`;
  const newPos=Math.min(me.position+total,30);
  const newLog=[...(room.log||[]),`${me.icon} ${me.name}: +${total} → ${newPos}. mező`].slice(-30);

  if(newPos>=30){
    await db.ref('rooms/'+myRoom).update({
      [`players/${me.id}/position`]:30,
      [`players/${me.id}/bonusNext`]:0,
      status:'finished',winner:{name:me.name,icon:me.icon},
      log:[...newLog,`🏆 ${me.name} NYERT!`],
      lastAction:{type:'win',ts:Date.now()}
    });
    return;
  }

  const cell=CELLS[newPos];
  let deck=[...(room.deck||mkDeck())];
  let action={type:'move',pos:newPos,cell:cell.t,pid:me.id,ts:Date.now()};

  if(cell.t==='card'){
    if(deck.length===0) deck=mkDeck();
    const card=deck.pop();
    action={type:'card',pos:newPos,card,pid:me.id,ts:Date.now()};
    await db.ref('rooms/'+myRoom).update({
      [`players/${me.id}/position`]:newPos,[`players/${me.id}/bonusNext`]:0,
      deck,log:newLog,lastAction:action
    });
  } else if(cell.t==='ruminate'){
    await db.ref('rooms/'+myRoom).update({
      [`players/${me.id}/position`]:newPos,[`players/${me.id}/bonusNext`]:0,
      log:newLog,lastAction:{type:'ruminate',pid:me.id,ts:Date.now()}
    });
  } else if(cell.t==='skip'){
    await db.ref('rooms/'+myRoom).update({
      [`players/${me.id}/position`]:newPos,[`players/${me.id}/bonusNext`]:0,
      log:newLog,lastAction:{type:'cellskip',pid:me.id,ts:Date.now()}
    });
  } else {
    const nextIdx=(cidx+1)%players.length;
    await db.ref('rooms/'+myRoom).update({
      [`players/${me.id}/position`]:newPos,[`players/${me.id}/bonusNext`]:0,
      currentPlayerIdx:nextIdx,log:newLog,lastAction:{type:'done',ts:Date.now()}
    });
  }
}

// ============================================================
//  HANDLE ACTIONS
// ============================================================
function handleAction(room,players,cidx){
  const a=room.lastAction; if(!a||!a.ts) return;
  lastTs=a.ts;
  const me=players[cidx];
  const isMyTurn=me&&me.id===myId;

  if(a.type==='ruminate'){
    showModal('↩','🐄 Kérődzés!','A bendőd visszaküldi az ételt! Rágd meg újra!','Vissza a szájhoz! (1. mező)',async()=>{
      if(!isMyTurn) return;
      const nextIdx=(cidx+1)%players.length;
      await db.ref('rooms/'+myRoom).update({
        [`players/${me.id}/position`]:1,currentPlayerIdx:nextIdx,
        log:[...(room.log||[]),`↩ ${me.name} vissza a szájhoz!`].slice(-30),
        lastAction:{type:'done',ts:Date.now()}
      });
    },isMyTurn);
  } else if(a.type==='cellskip'){
    showModal('⏸','Százrétű labirintus!','Elvesztél a lemezek között!','Kimaradsz 1 körből! ⏸',async()=>{
      if(!isMyTurn) return;
      const nextIdx=(cidx+1)%players.length;
      await db.ref('rooms/'+myRoom).update({
        [`players/${me.id}/skipTurns`]:(me.skipTurns||0)+1,currentPlayerIdx:nextIdx,
        lastAction:{type:'done',ts:Date.now()}
      });
    },isMyTurn);
  } else if(a.type==='card'){
    const card=a.card;
    showModal(card.ico,card.tit,card.txt,card.eff,async()=>{
      if(!isMyTurn) return;
      await applyCard(card,me,players,cidx,room);
    },isMyTurn);
  }
}

async function applyCard(card,me,players,cidx,room){
  const nextIdx=(cidx+1)%players.length;
  const log=room.log||[];
  let upd={lastAction:{type:'done',ts:Date.now()}};
  if(card.act==='back'){
    upd[`players/${me.id}/position`]=1; upd.currentPlayerIdx=nextIdx;
    upd.log=[...log,`↩ ${me.name} vissza a szájhoz!`].slice(-30);
  } else if(card.act==='fwd'){
    const np=Math.min(me.position+card.val,30);
    upd[`players/${me.id}/position`]=np; upd.currentPlayerIdx=nextIdx;
    upd.log=[...log,`➡ ${me.name} előre ${card.val}`].slice(-30);
    if(np>=30){upd.status='finished';upd.winner={name:me.name,icon:me.icon};}
  } else if(card.act==='bwd'){
    upd[`players/${me.id}/position`]=Math.max(me.position-card.val,1); upd.currentPlayerIdx=nextIdx;
    upd.log=[...log,`⬅ ${me.name} vissza ${card.val}`].slice(-30);
  } else if(card.act==='skip'){
    upd[`players/${me.id}/skipTurns`]=(me.skipTurns||0)+1; upd.currentPlayerIdx=nextIdx;
    upd.log=[...log,`⏸ ${me.name} kimarad 1 körből`].slice(-30);
  } else if(card.act==='bonus'){
    upd[`players/${me.id}/bonusNext`]=(me.bonusNext||0)+card.val; upd.currentPlayerIdx=nextIdx;
    upd.log=[...log,`🌿 ${me.name} +${card.val} következő körben`].slice(-30);
  } else if(card.act==='reroll'){
    upd.log=[...log,`💨 ${me.name} újra dobhat!`].slice(-30);
    // nem lép tovább a sor
  } else {
    upd.currentPlayerIdx=nextIdx;
  }
  await db.ref('rooms/'+myRoom).update(upd);
}

