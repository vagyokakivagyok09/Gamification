function drawBoard(){
  cellPos=buildPath();
  const cg=document.getElementById('cg'); cg.innerHTML='';
  const poly=document.createElementNS('http://www.w3.org/2000/svg','polyline');
  poly.setAttribute('points',cellPos.map(p=>p.x+','+p.y).join(' '));
  poly.setAttribute('fill','none');poly.setAttribute('stroke','#8b5e3c');
  poly.setAttribute('stroke-width','3');poly.setAttribute('stroke-dasharray','6,4');poly.setAttribute('opacity','0.3');
  cg.appendChild(poly);
  cellPos.forEach(({x,y},idx)=>{
    const ci=idx+1,cell=CELLS[ci]; if(!cell) return;
    const r=(cell.t==='start'||cell.t==='goal')?27:23;
    const circ=document.createElementNS('http://www.w3.org/2000/svg','circle');
    circ.setAttribute('cx',x);circ.setAttribute('cy',y);circ.setAttribute('r',r);
    circ.setAttribute('fill',cell.c||'#d4c89a');circ.setAttribute('stroke','#4a2e1a');
    circ.setAttribute('stroke-width',cell.t==='ruminate'?'3':'1.5');
    if(cell.t==='card'){circ.setAttribute('stroke','#2a5a85');circ.setAttribute('stroke-dasharray','4,2');}
    cg.appendChild(circ);
    const lines=cell.l.split('\n');
    [[lines[0],y+(lines.length>1?-5:4),'12'],[lines[1]&&lines[1],y+9,'7']].forEach(([txt,cy,fs])=>{
      if(!txt) return;
      const t=document.createElementNS('http://www.w3.org/2000/svg','text');
      t.setAttribute('x',x);t.setAttribute('y',cy);t.setAttribute('text-anchor','middle');
      t.setAttribute('font-family','Patrick Hand,cursive');t.setAttribute('font-size',cell.t==='start'||cell.t==='goal'?'10':fs);
      t.setAttribute('font-weight','bold');t.setAttribute('fill',cell.tc||'#2c1a0e');
      t.textContent=txt; cg.appendChild(t);
    });
  });
}

function renderPawns(players,cidx){
  const pg=document.getElementById('pg'); pg.innerHTML='';
  const offs=[{x:-10,y:-10},{x:10,y:-10},{x:-10,y:10},{x:10,y:10},{x:0,y:-16},{x:16,y:0}];
  players.forEach((p,pi)=>{
    const ci=Math.min(p.position-1,cellPos.length-1);
    const pos=cellPos[ci]; if(!pos) return;
    const off=offs[pi%offs.length];
    if(pi===cidx){
      const ring=document.createElementNS('http://www.w3.org/2000/svg','circle');
      ring.setAttribute('cx',pos.x+off.x);ring.setAttribute('cy',pos.y+off.y-6);
      ring.setAttribute('r','13');ring.setAttribute('fill','none');
      ring.setAttribute('stroke','#e8c84a');ring.setAttribute('stroke-width','2.5');
      pg.appendChild(ring);
    }
    const t=document.createElementNS('http://www.w3.org/2000/svg','text');
    t.setAttribute('x',pos.x+off.x);t.setAttribute('y',pos.y+off.y);
    t.setAttribute('text-anchor','middle');t.setAttribute('font-size','17');
    t.setAttribute('filter','url(#sh)');t.textContent=p.icon; pg.appendChild(t);
  });
}

function renderPlayers(players,cidx){
  document.getElementById('pl').innerHTML=players.map((p,i)=>`
    <div class="pcard${i===cidx?' cur':''}${p.id===myId?' me':''}">
      <span class="pico">${p.icon}</span>
      <div><div class="pname">${p.name}${p.id===myId?' (én)':''}</div>
      <div class="ppos">${p.position}. mező${p.skipTurns>0?' ⏸':''}</div></div>
    </div>`).join('');
}

function renderLog(log){
  const el=document.getElementById('elog');
  el.innerHTML=log.map(e=>{
    let c='ev';
    if(e.includes('→')) c='mv';
    if(e.includes('↩')||e.includes('➡')||e.includes('⬅')) c='cd';
    if(e.includes('🏆')) c='wn';
    return `<div class="le ${c}">${e}</div>`;
  }).join('');
  el.scrollTop=el.scrollHeight;
}

