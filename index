function mkDeck(){
  const d=[...CARDS,...CARDS.slice(0,6)];
  for(let i=d.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[d[i],d[j]]=[d[j],d[i]];}
  return d;
}

function buildPath(){
  const p=[];
  for(let i=0;i<8;i++) p.push({x:80+i*60,y:55});
  for(let i=1;i<=7;i++) p.push({x:500,y:55+i*52});
  for(let i=1;i<=7;i++) p.push({x:500-i*60,y:419});
  for(let i=0;i<8;i++) p.push({x:80+i*60,y:471});
  return p;
}

